# Obsidian — личные настройки рабочего пространства (не нужны коллегам)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# Корзина Obsidian
.trash/

# LaTeX — временные файлы компиляции (не нужны в репозитории)
*.aux
*.log
*.bcf
*.blg
*.bbl
*.out
*.run.xml
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
texput.log

# LaTeX — скомпилированные PDF (тяжёлые бинарники, регенерируются)
sources/chapters/**/*.pdf
sources/*.pdf

# Учебники и источники в PDF (авторские права + большой размер)
# Сводки-index.md хранятся в git, сами PDF — только локально
sources/**/*.pdf

# Системные файлы Windows
Thumbs.db
desktop.ini

# macOS (на случай если коллеги на маке)
.DS_Store
