% -----------------------------------------------------------------------
% 12. СРЕДЫ — tcolorbox с вертикальной линией слева
%   definition  — indigo,   1.5pt
%   theorem     — darkred,  1pt, курсив
%   example     — без выделения, только метка капителью
%   proof       — без выделения, капитель + отступ
% -----------------------------------------------------------------------
\RequirePackage[skins, breakable]{tcolorbox}

\newcounter{defcounter}[chapter]
\newcounter{thmcounter}[chapter]
\newcounter{excounter}[chapter]

\tcbset{
  envstyle/.style={
    blanker,
    breakable,
    left=8pt,
    top=3pt,
    bottom=3pt,
    before upper={\setlength{\parindent}{0pt}},
    parbox=false,
  }
}

% Определение — indigo, 1.5pt
\newenvironment{definition}{%
  \refstepcounter{defcounter}%
  \begin{tcolorbox}[
    envstyle,
    borderline west={1.5pt}{0pt}{indigo},
    before skip=0.5\baselineskip,
    after skip=0.3\baselineskip,
  ]%
  {\scshape Определение \thedefcounter.}\ \normalfont\ignorespaces
}{%
  \end{tcolorbox}%
}

% Теорема — darkred, 1pt, курсив
\newenvironment{theorem}{%
  \refstepcounter{thmcounter}%
  \begin{tcolorbox}[
    envstyle,
    borderline west={1pt}{0pt}{darkred},
    before skip=0.5\baselineskip,
    after skip=0.3\baselineskip,
  ]%
  {\scshape Теорема \thethmcounter.}\ \itshape\ignorespaces
}{%
  \end{tcolorbox}%
}

% Пример — без выделения
\newenvironment{example}{%
  \par\vspace{0.4\baselineskip}%
  \noindent\refstepcounter{excounter}%
  {\scshape Пример \theexcounter.}\ \normalfont\ignorespaces
}{%
  \par\vspace{0.3\baselineskip}%
}

% Доказательство — без выделения
\newenvironment{proof}{%
  \par\vspace{0.3\baselineskip}%
  \noindent{\scshape Доказательство.}\ \normalfont\ignorespaces
}{%
  \hfill\textit{ч.т.д.}\par\vspace{0.2\baselineskip}%
}

