% чётная  (левая):  название параграфа — номер страницы
% нечётная (правая): номер страницы — название параграфа
% -----------------------------------------------------------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}

\fancyhead[LE]{\small\headingfont\nouppercase{\rightmark}}
\fancyhead[RE]{\small\headingfont\thepage}
\fancyhead[LO]{\small\headingfont\thepage}
\fancyhead[RO]{\small\headingfont\nouppercase{\rightmark}}

\renewcommand{\headrulewidth}{0.5pt}
\renewcommand{\footrulewidth}{0pt}

% Страница начала главы — номер внизу по центру, без верхней линии
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  }

\renewcommand{\mainmatter}{%
  \@mainmattertrue%
  \setcounter{secnumdepth}{3}%
}
