% -----------------------------------------------------------------------
% 8. ЗАГОЛОВКИ — titlesec
% -----------------------------------------------------------------------
\RequirePackage{titlesec}

% \chapter — номер Inter Light 48pt серый, название Inter Regular 18pt
\titleformat{\chapter}[display]
  {\headingfont}
  {{\headinglight\fontsize{48}{52}\selectfont\color{chaptergray}\thechapter}}
  {8pt}
  {\fontsize{18}{22}\selectfont}
\titlespacing*{\chapter}
  {0pt}{60pt plus 6pt minus 4pt}{28pt plus 4pt minus 2pt}

% \chapter* — ненумерованная глава
\titleformat{name=\chapter,numberless}[block]
  {\headingfont\fontsize{18}{22}\selectfont}
  {}
  {0pt}
  {}
\titlespacing*{name=\chapter,numberless}
  {0pt}{60pt plus 6pt minus 4pt}{28pt plus 4pt minus 2pt}

% \section — § N.  Название  (Inter Medium, 14pt, влево)
\titleformat{\section}[block]
  {\headingmedium\fontsize{14}{18}\selectfont}
  {\S\,\thesection.}
  {0.6em}
  {}
\titlespacing*{\section}
  {0pt}{1.2\baselineskip plus 0.3\baselineskip minus 0.2\baselineskip}
       {0.4\baselineskip plus 0.1\baselineskip}

% \section* — ненумерованный параграф
\titleformat{name=\section,numberless}[block]
  {\headingmedium\fontsize{14}{18}\selectfont}
  {}
  {0pt}
  {}
\titlespacing*{name=\section,numberless}
  {0pt}{1.2\baselineskip plus 0.3\baselineskip minus 0.2\baselineskip}
       {0.4\baselineskip plus 0.1\baselineskip}

% \subsection — Inter Medium, 12pt, влево
\titleformat{\subsection}[block]
  {\headingmedium\fontsize{12}{15}\selectfont}
  {\thesubsection.}
  {0.5em}
  {}
\titlespacing*{\subsection}
  {0pt}{0.8\baselineskip plus 0.2\baselineskip minus 0.1\baselineskip}
       {0.25\baselineskip plus 0.1\baselineskip}

% Сквозная нумерация section, subsection без номера chapter
\counterwithout{section}{chapter}
\renewcommand{\thesubsection}{\arabic{section}.\arabic{subsection}}

