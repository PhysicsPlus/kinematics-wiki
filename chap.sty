  SmallCapsFeatures={Scale=1.12}
]
\setsansfont{STIX Two Text}
\setmonofont{Anonymous Pro}

% Гротеск для заголовков — Inter
\newfontfamily\headingfont{Inter}[
  UprightFont    = *-Regular,
  BoldFont       = *-SemiBold,
  ItalicFont     = *-Italic,
  BoldItalicFont = *-SemiBoldItalic,
  Ligatures      = TeX,
  Renderer       = Harfbuzz
]
\newfontfamily\headinglight{Inter}[
  UprightFont = *-Light,
  Ligatures   = TeX,
  Renderer    = Harfbuzz
]
\newfontfamily\headingmedium{Inter}[
  UprightFont = *-Medium,
  Ligatures   = TeX,
  Renderer    = Harfbuzz
]

